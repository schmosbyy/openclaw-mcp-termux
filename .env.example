# === REQUIRED ===

# URL of your running OpenClaw gateway (never change this on Android - it's always loopback)
OPENCLAW_URL=http://127.0.0.1:18789

# Bearer token from your openclaw.json gateway.auth.token (found in ~/.openclaw/secrets.json)
OPENCLAW_GATEWAY_TOKEN=

# === REMOTE HTTP MODE ONLY ===

# Token that MCP clients use to authenticate to THIS bridge (generate with scripts/gen-token.sh)
BRIDGE_TOKEN=

# Port for the HTTP server (default: 3000)
PORT=3000

# === OPTIONAL ===

# Path to the openclaw binary or wrapper script used for gateway restart.
# Override this if your openclaw binary is not at the default location.
OPENCLAW_BIN_PATH=/data/data/com.termux/files/home/bin/openclaw-proot.sh

# MCP gateway request timeout in ms. Should exceed subagent runTimeoutSeconds (currently 600s).
# Default: 1800000 (30 minutes)
OPENCLAW_TIMEOUT_MS=1800000

# Set to 'true' to see verbose request/response logging
DEBUG=false

# Device ID from ~/.openclaw/devices/paired.json — the linux/gateway-client device
# If unset, the bridge auto-detects by scanning for platform=linux
OPENCLAW_DEVICE_ID=
